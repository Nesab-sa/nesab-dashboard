rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔑 Check if user is logged in
    function isSignedIn() {
      return request.auth != null;
    }

    // 👑 Check if user is admin (manager)
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/managers/$(request.auth.uid));
    }

    /* ===================== MANAGERS ===================== */
    match /managers/{userId} {

      // المدير يقدر يقرأ كل المدراء (dashboard)
      allow read: if isAdmin();

      // لا أحد يكتب من التطبيق (يتم من Firebase console فقط)
      allow write: if false;
    }

    /* ===================== CATEGORIES ===================== */
    match /categories/{categoryId} {

      // القراءة متاحة لكل المستخدمين المسجلين
      allow read: if isSignedIn();

      // الكتابة للمدير فقط
      allow create, update, delete: if isAdmin();
    }

    /* ===================== USERS ===================== */
    match /users/{userId} {

      // المستخدم يقرأ نفسه
      allow read: if isSignedIn() && request.auth.uid == userId;

      // المدير يقرأ أي مستخدم
      allow read: if isAdmin();

      // لا نسمح بالكتابة حالياً
      allow write: if false;
    }

    /* ===================== BLOCKED COLLECTIONS ===================== */
    match /settings/{docId} {
      allow read, write: if false;
    }

    match /rate_limits/{userId}/{document=**} {
      allow read, write: if false;
    }

    match /rate_limits_web/{ipKey}/{document=**} {
      allow read, write: if false;
    }
  }
}