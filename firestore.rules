rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────
    // Admins can list all users; regular users can only access their own doc.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Managers (dashboard admin login + management) ──────
    match /managers/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Categories ─────────────────────────────────────────
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Bank Rates / Profit Margins ───────────────────────
    match /bank_rates/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── App Notifications ─────────────────────────────────
    match /app_notifications/{notifId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      match /acknowledgments/{ackId} {
        allow read, write: if request.auth != null;
      }
    }

    // ── AI Config ─────────────────────────────────────────
    match /ai_config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── AI Conversations ──────────────────────────────────
    match /ai_conversations/{convId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── App Config / Pages ────────────────────────────────
    match /app_config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Tools ─────────────────────────────────────────────
    match /tools/{toolId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
